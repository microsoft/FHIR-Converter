{%- unless vars.selectionCriteria -%}
  {{ "selectionCriteria variable is required but was not provided." | raise_error }}
{%- endunless -%}
{%- assign matched = msg.identifier | select_identifier: vars.selectionCriteria -%}
{% mergeDiff msg -%}
{
  "identifier": [
    {% for id in msg.identifier -%}
      {{ id | to_json_string }},
    {% endfor -%}
    {
      "use": {{ matched.use | to_json_string | default: '"official"' }},
      "type": {{ matched.type | to_json_string }},
      "system": {{ vars.selectionCriteria.outputSystem | to_json_string }},
      "value": {{ matched.value | to_json_string }}
    }
  ]
}
{% endmergeDiff -%}
